# The full workflow to check Platform SSO status and if required open interfaces and dialogs to register with Platform SSO.
workflow_psso() {
	local workflow_psso_error
	workflow_psso_error="FALSE"
	psso_workflow_smartcard_active="FALSE"
	psso_workflow_main_active="FALSE"
	psso_workflow_user_active="FALSE"
	
	# Initial Platform SSO configuration checks. This sets ${psso_extension_identifier}, ${psso_login_type}, and ${psso_display_name}.
	if [[ -e "${SSO_MANAGED_PLIST}" ]]; then
		psso_extension_identifier=$(/usr/libexec/PlistBuddy -c "Print :ExtensionIdentifier" "${SSO_MANAGED_PLIST}" 2> /dev/null)
		psso_login_type=$(/usr/libexec/PlistBuddy -c "Print :PlatformSSO:AuthenticationMethod" "${SSO_MANAGED_PLIST}" 2> /dev/null)
		psso_display_name=$(/usr/libexec/PlistBuddy -c "Print :PlatformSSO:AccountDisplayName" "${SSO_MANAGED_PLIST}" 2> /dev/null)
	fi
	if [[ -z "${psso_extension_identifier}" ]] || [[ -z "${psso_login_type}" ]] || [[ -z "${psso_display_name}" ]]; then
		log_pseudo "Warning: Could not resolve required Plaftorm SSO attributes from the managed preference located at ${SSO_MANAGED_PLIST}:\n$(/usr/libexec/PlistBuddy -c "Print :" "${SSO_MANAGED_PLIST}" 2> /dev/null)"
		log_pseudo "Status: Attempting failover configuration validation via app-sso command..."
		killall "AppSSOAgent" > /dev/null 2>&1
		sleep 1
		local app_sso_response
		app_sso_response=$(app-sso platform -s)
		[[ -z "${psso_extension_identifier}" ]] && psso_extension_identifier=$(echo "${app_sso_response}" | sed -e '1,/Device Configuration:/d' | jq -r '.extensionIdentifier' 2> /dev/null)
		[[ -z "${psso_login_type}" ]] && psso_login_type=$(echo "${app_sso_response}" | sed -e '1,/Device Configuration:/d' | jq -r '.loginType' 2> /dev/null)
		[[ -z "${psso_display_name}" ]] && psso_display_name=$(echo "${app_sso_response}" | sed -e '1,/Device Configuration:/d' | jq -r '.accountDisplayName' 2> /dev/null)
	fi
	if [[ -z "${psso_extension_identifier}" ]] || [[ -z "${psso_login_type}" ]] || [[ -z "${psso_display_name}" ]]; then
		log_pseudo "Warning: Could not resolve required Plaftorm SSO attributes from the app-sso command results:\n${app_sso_response}"
		[[ -z "${psso_extension_identifier}" ]] && log_pseudo "Error: Could not determine Platform SSO extension identifier. This is a required value for Platform SSO." && workflow_psso_error="TRUE"
		[[ -z "${psso_login_type}" ]] && log_pseudo "Error: Could not determine Platform SSO login type. This is a required value for Platform SSO." && workflow_psso_error="TRUE"
		[[ -z "${psso_display_name}" ]] && log_pseudo "Error: Could not determine Platform SSO account display name. This is a required value for the pseudo workflow." && workflow_psso_error="TRUE"
	fi
	
	# Platform SSO extension application checks. This sets ${psso_dialog_idp_string}, ${psso_login_type_string}, and ${psso_dialog_icon}.
	if [[ "${psso_extension_identifier}" == "com.microsoft.CompanyPortalMac.ssoextension" ]]; then
		if [[ -e "/Applications/Company Portal.app" ]]; then
			psso_dialog_idp_string="Entra ID"
			psso_dialog_icon="/Applications/Company Portal.app/Contents/Resources/AppIcon.icns"
		else
			log_pseudo "Error: The required Platform SSO software Company Portal.app is not installed." && workflow_psso_error="TRUE"
		fi
	fi
	if [[ "${psso_extension_identifier}" == "com.okta.mobile.auth-service-extension" ]]; then
		if [[ -e "/Applications/Okta Verify.app" ]]; then
			psso_dialog_idp_string="Okta"
			psso_dialog_icon="/Applications/Okta Verify.app/Contents/Resources/AppIcon.icns"
			check_current_user_default_browser
			[[ -z "${current_user_default_browser}" ]] && workflow_psso_error="TRUE"
		else
			log_pseudo "Error: The required Platform SSO software Okta Verify.app is not installed." && workflow_psso_error="TRUE"
		fi
	fi
	if [[ "${workflow_psso_error}" == "FALSE" ]]; then
		[[ $(echo "${psso_login_type}" | grep -c 'SecureEnclave') -gt 0 ]] && psso_login_type_string="Secure Enclave"
		[[ $(echo "${psso_login_type}" | grep -c 'SmartCard') -gt 0 ]] && psso_login_type_string="PIV/SmartCard"
		[[ $(echo "${psso_login_type}" | grep -c 'Password') -gt 0 ]] && psso_login_type_string="IdP Password"
		log_pseudo "Status: Platform SSO configuration for ${psso_dialog_idp_string} using ${psso_login_type_string} authentication with the display name \"${psso_display_name}\"."
	else
		log_pseudo "Exit: Platform SSO workflow failed due to errors." && exit_error
	fi
	
	# If Platform SSO is already enabled then skip the workflow except for enabling AutoFill extensions.
	check_psso_user_status
	if [[ "${REPAIR_MODE}" != "TRUE" ]] && [[ "${psso_user_status_dscl}" != "FALSE" ]] && [[ "${psso_user_status_login_name}" != "FALSE" ]] && [[ $(echo "${psso_user_status_state}" | grep -c 'Normal') -gt 0 ]]; then
		log_pseudo "Status: Platform SSO is already registered for local user ${current_user_account_name} (${current_user_id}) to account ${psso_user_status_login_name}."
		[[ "${ENABLE_AUTOFILL_EXTENSIONS}" == "TRUE" ]] && enable_psso_autofill_extensions
		[[ "${UPDATE_JAMF_PRO}" == "TRUE" ]] && jamf_pro_update_inventory # This function has no user dialogs.
		return 0
	fi
	
	# Handle the initial Platform SSO Registration dialog.
	local psso_registration_status
	psso_registration_status=$(check_psso_registration_status)
	if [[ "${REPAIR_MODE}" != "TRUE" ]] && { [[ "${psso_registration_status}" == "FALSE" ]] || [[ "${psso_registration_status}" == "CLOSE" ]]; }; then
		log_pseudo "Status: Informing user that Platform SSO is required and will be configured for local user ${current_user_account_name} (${current_user_id})."
		open_dialog_psso_required
		if [[ "${dialog_psso_required_result}" -eq 4 ]]; then
			log_pseudo "Error: The initial Platform SSO workflow dialog timed out after ${TIMEOUT_DIALOG_SECONDS} seconds." && workflow_psso_error="TRUE"
		elif [[ "${dialog_psso_required_result}" -gt 0 ]]; then
			log_pseudo "Error: The initial Platform SSO workflow dialog returned unexpected result: ${dialog_psso_required_result}" && workflow_psso_error="TRUE"
		fi
	fi
	
	# If the authentication workflow requires a SmartCard then make sure the user has their SmartCard attached.
	if [[ "${workflow_psso_error}" == "FALSE" ]] && [[ $(echo "${psso_login_type}" | grep -c 'SmartCard') -gt 0 ]]; then
		if [[ $(security list-smartcards 2>&1 | grep -c "No smartcards found.") -gt 0 ]]; then
			log_pseudo "Status: Starting Platform SSO registration workflow by waiting for a SmartCard with a ${TIMEOUT_WORKFLOW_SECONDS} second timeout..."
			psso_workflow_smartcard_active="TRUE"
			open_dialog_smartcard_required
			focus_psso_registration
			local psso_smartcard_start_epoch
			psso_smartcard_start_epoch=$(date +%s)
			while [[ $(security list-smartcards 2>&1 | grep -c "No smartcards found.") -gt 0 ]]; do
				if [[ $(( psso_smartcard_start_epoch + TIMEOUT_WORKFLOW_SECONDS )) -lt $(date +%s) ]]; then
					log_pseudo "Error: Waiting for a SmartCard timed out after ${TIMEOUT_WORKFLOW_SECONDS} seconds." && workflow_psso_error="TRUE"
					break
				fi
				focus_psso_registration
				sleep 1
			done
		fi
		smartcard_array=($(security list-smartcards 2> /dev/null))
		if [[ -n "${smartcard_array[*]}" ]]; then
			[[ "${psso_workflow_smartcard_active}" == "FALSE" ]] && log_pseudo "Status: A SmartCard is already attached."
			[[ "${psso_workflow_smartcard_active}" == "TRUE" ]] && log_pseudo "Status: A SmartCard is now attached. Waiting for a SmartCard took $(( $(date +%s) - psso_smartcard_start_epoch )) seconds to complete."
		else
			log_pseudo "Error: Unable to acquire SmartCard listing." && workflow_psso_error="TRUE"
		fi
	fi
	
	# At this point it's time to open Platform SSO registration.
	if [[ "${workflow_psso_error}" == "FALSE" ]]; then
		[[ "${psso_workflow_smartcard_active}" == "FALSE" ]] && log_pseudo "Status: Starting Platform SSO registration workflow with a ${TIMEOUT_WORKFLOW_SECONDS} second timeout..."
		[[ "${psso_workflow_smartcard_active}" == "TRUE" ]] && log_pseudo "Status: Continuing Platform SSO registration workflow with a ${TIMEOUT_WORKFLOW_SECONDS} second timeout..."
		[[ -n "${current_user_default_browser}" ]] && do_not_hide_bundle_id="${current_user_default_browser}"
		psso_workflow_main_active="TRUE"
		local psso_registration_status
		local psso_workflow_start_epoch
		psso_workflow_start_epoch=$(date +%s)
		[[ "${ENABLE_AUTOFILL_EXTENSIONS}" == "TRUE" ]] && enable_psso_autofill_extensions
		log_pseudo "Status: Attempting to open Platform SSO registration..."
		[[ $(open_psso_registration) == "FALSE" ]] && log_pseudo "Error: Opening Platform SSO registration timed out after ${TIMEOUT_OPEN_SECONDS} seconds." && workflow_psso_error="TRUE"
		[[ "${workflow_psso_error}" == "FALSE" ]] && open_dialog_psso_start
		while [[ "${workflow_psso_error}" == "FALSE" ]] && { [[ "${REPAIR_MODE}" == "TRUE" ]] || [[ "${psso_user_status_dscl}" == "FALSE" ]] || [[ "${psso_user_status_login_name}" == "FALSE" ]]; }; do
			if [[ $(( psso_workflow_start_epoch + TIMEOUT_WORKFLOW_SECONDS )) -lt $(date +%s) ]]; then
				log_pseudo "Error: Platform SSO registration workflow timed out after ${TIMEOUT_WORKFLOW_SECONDS} seconds." && workflow_psso_error="TRUE"
				break
			fi
			[[ -z "${do_not_hide_bundle_id}" ]] && focus_psso_registration
			psso_registration_status=$(check_psso_registration_status)
			if [[ "${psso_registration_status}" == "ACTIVE" ]] && [[ "${psso_workflow_user_active}" == "FALSE" ]]; then
				log_pseudo "Status: Platform SSO registration is open and the user is actively registering."
				open_dialog_psso_active
				psso_workflow_user_active="TRUE"
			elif [[ "${psso_registration_status}" == "AUTOFILL" ]]; then
				break
			elif [[ "${psso_registration_status}" == "FALSE" ]]; then
				log_pseudo "Status: Attempting to re-open Platform SSO registration (the user likely closed the registration window)..."
				[[ $(open_psso_registration) == "FALSE" ]] && log_pseudo "Error: Opening Platform SSO registration timed out after ${TIMEOUT_OPEN_SECONDS} seconds." && workflow_psso_error="TRUE"
				[[ "${workflow_psso_error}" == "TRUE" ]] && break
			elif [[ "${psso_registration_status}" == "CLOSE" ]]; then
				check_psso_user_status
				{ [[ "${psso_user_status_dscl}" == "FALSE" ]] || [[ "${psso_user_status_login_name}" == "FALSE" ]]; } && log_pseudo "Error: Detected Platform SSO registration interface failure." && workflow_psso_error="TRUE"
				break
			fi
			sleep 1
			check_psso_user_status
		done
		[[ -n "${do_not_hide_bundle_id}" ]] && unset do_not_hide_bundle_id
	fi
	
	# At this point the user is technically registered for SSO but may need to complete other tasks.
	if [[ "${workflow_psso_error}" == "FALSE" ]] && [[ "${psso_workflow_user_active}" == "TRUE" ]]; then
		local psso_workflow_end_epoch
		psso_registration_status=$(check_psso_registration_status)
		if [[ "${ENABLE_AUTOFILL_EXTENSIONS}" == "TRUE" ]] && [[ "${psso_registration_status}" == "AUTOFILL" ]]; then
			log_pseudo "Status: Closing Platform SSO registration AutoFill window..."
			close_psso_registration_autofill
			psso_registration_status=$(check_psso_registration_status)
		fi
		if [[ $(echo "${psso_login_type}" | grep -c 'Password') -gt 0 ]] && [[ "${psso_registration_status}" == "ACTIVE" ]]; then
			log_pseudo "Status: Waiting for IdP password sync to local user account..."
			open_dialog_password_sync
			psso_workflow_end_epoch=$(date +%s)
			while [[ "${psso_registration_status}" != "CLOSE" ]]; do
				if [[ $(( psso_workflow_end_epoch + TIMEOUT_WORKFLOW_SECONDS )) -lt $(date +%s) ]]; then
					log_pseudo "Error: IdP password sync timed out after ${TIMEOUT_WORKFLOW_SECONDS} seconds." && workflow_psso_error="TRUE"
					break
				fi
				focus_psso_registration
				sleep 1
				psso_registration_status=$(check_psso_registration_status)
			done
			[[ "${workflow_psso_error}" == "FALSE" ]] && log_pseudo "Status: IdP password sync took $(( $(date +%s) - psso_workflow_end_epoch )) seconds to complete."
		fi
		if [[ $(echo "${psso_login_type}" | grep -c 'SmartCard') -gt 0 ]] && [[ "$(check_psso_smartcard_auth_status)" == "TRUE" ]]; then
			log_pseudo "Status: Waiting for SmartCard paring to local user account..."
			open_dialog_smartcard_pairing
			psso_workflow_end_epoch=$(date +%s)
			while [[ "$(check_psso_smartcard_auth_status)" == "TRUE" ]] || [[ "${psso_registration_status}" != "CLOSE" ]]; do
				if [[ $(( psso_workflow_end_epoch + TIMEOUT_WORKFLOW_SECONDS )) -lt $(date +%s) ]]; then
					log_pseudo "Error: SmartCard paring timed out after ${TIMEOUT_WORKFLOW_SECONDS} seconds." && workflow_psso_error="TRUE"
					break
				fi
				focus_psso_registration
				sleep 1
				psso_registration_status=$(check_psso_registration_status)
			done
			[[ "${workflow_psso_error}" == "FALSE" ]] && log_pseudo "Status: SmartCard paring took $(( $(date +%s) - psso_workflow_end_epoch )) seconds to complete."
		fi
	fi
	
	# Handle any PSSO workflow errors and exit.
	if [[ "${workflow_psso_error}" == "FALSE" ]]; then
		log_pseudo "Status: Platform SSO is now registered for local user ${current_user_account_name} (${current_user_id}) to account ${psso_user_status_login_name}. The Platform SSO workflow took $(( $(date +%s) - psso_workflow_start_epoch )) seconds to complete."
		close_psso_registration
		echo "quit:" >> "${SWIFT_DIALOG_COMMAND_FILE}" && sleep 0.1
		if [[ "${UPDATE_JAMF_PRO}" == "TRUE" ]]; then
			jamf_pro_update_inventory
		elif [[ "${UPDATE_WORKSPACE_ONE}" == "TRUE" ]]; then
			workspace_one_update_inventory
			open_dialog_psso_success & disown
		else
			open_dialog_psso_success & disown
		fi
	else
		killall "AppSSOAgent" > /dev/null 2>&1
		{ [[ "${psso_workflow_smartcard_active}" == "TRUE" ]] || [[ "${psso_workflow_main_active}" == "TRUE" ]]; } && open_dialog_psso_failed & disown
		log_pseudo "Exit: Platform SSO workflow failed due to errors." && exit_error
	fi
}

# MARK: *** Main Workflow ***
################################################################################

main() {
	workflow_startup # This function only completes if the system and user are ready to complete further workflows.
	[[ "${REPAIR_MODE}" != "TRUE" ]] && workflow_touch_id # If Touch ID is available and required then this function only completes if the user has enabled Touch ID.
	workflow_psso # This function only completes if the user has successfully registred with Platform SSO.
	[[ "${update_inventory_error}" == "TRUE" ]] && log_pseudo "Exit: Unable to fully complete the requested inventory update." && exit_error
}

main "$@"
exit_success
