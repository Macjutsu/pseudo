	end if
end tell
tell application "System Events"
	set visibleApps to every process whose visible is true and name is not "System Settings" and name is not "Dialog" and name is not "Finder" and bundle identifier is not "${do_not_hide_bundle_id}"
	repeat with anApp in visibleApps
		tell anApp to set visible to false
